<?xml version="1.0"?>
<robot name="six_axis_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== MATERIALS ===================== -->
  <material name="blue_grey">
    <color rgba="0.2 0.4 0.6 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <!-- ===================== BASE LINK ===================== -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.0067" ixy="0" ixz="0"
               iyy="0.0067" iyz="0" izz="0.0098"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 1 + LINK 1 ===================== -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child  link="link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="100" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.2"/></geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.0058" ixy="0" ixz="0"
               iyy="0.0058" iyz="0" izz="0.0023"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 2 + LINK 2 ===================== -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child  link="link_2"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708"
           effort="100" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.05" length="0.3"/></geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.05" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0.15 0 0"/>
      <inertia ixx="0.0018" ixy="0" ixz="0"
               iyy="0.0094" iyz="0" izz="0.0094"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 3 + LINK 3 ===================== -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child  link="link_3"/>
    <origin xyz="0.3 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708"
           effort="80" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0.125 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="0.25"/></geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="0.25"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0.125 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0"
               iyy="0.0055" iyz="0" izz="0.0055"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 4 + LINK 4 ===================== -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child  link="link_4"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="60" velocity="1.2"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.2"/></geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.0031" ixy="0" ixz="0"
               iyy="0.0031" iyz="0" izz="0.00064"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 5 + LINK 5 ===================== -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child  link="link_5"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708"
           effort="40" velocity="1.5"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0.04 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.035" length="0.08"/></geometry>
      <material name="blue_grey"/>
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.035" length="0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.04 0 0"/>
      <inertia ixx="0.00035" ixy="0" ixz="0"
               iyy="0.00035" iyz="0" izz="0.000153"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 6 + END EFFECTOR ===================== -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child  link="end_effector_link"/>
    <origin xyz="0.08 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="20" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <link name="end_effector_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- ===================== TRANSMISSIONS ===================== -->
  <transmission name="trans_1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="trans_2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="trans_3">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_3">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_3">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="trans_4">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_4">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_4">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="trans_5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_5">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_5">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="trans_6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_6">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_6">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ===================== GAZEBO PLUGIN ===================== -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
      <legacyModeNS>true</legacyModeNS>
    </plugin>
  </gazebo>

  <!-- Gazebo material colors -->
  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="link_1"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link_2"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link_3"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link_4"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link_5"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="end_effector_link"><material>Gazebo/DarkGrey</material></gazebo>

</robot>
